#!/bin/sh
#
# Pre-commit hook for LowEndInsight
#
# Runs tests before allowing commit.
# Enable with: git config core.hooksPath .githooks

set -e

echo "==> pre-commit: running tests..."
# git commit exports GIT_DIR, GIT_INDEX_FILE, GIT_WORK_TREE, etc. before running hooks.
# Some tests (git_module_local_test) call 'git commit' in subprocesses that inherit these
# vars, causing them to create commits on THIS branch and corrupt the index.
# Unset all GIT_* vars and save/restore the index so tests run in a clean git context.
INDEX_FILE="${GIT_INDEX_FILE:-$(git rev-parse --git-dir)/index}"
INDEX_BACKUP="/tmp/lei-pre-commit-index-$$"
cp "$INDEX_FILE" "$INDEX_BACKUP"

# Temporarily disable exit-on-error so we can inspect mix test's exit code.
# Exit code 0 = all pass; 1 = failures; 2 = some tests excluded (network/long) — treat as success.
set +e
env -u GIT_DIR -u GIT_INDEX_FILE -u GIT_WORK_TREE -u GIT_OBJECT_DIRECTORY \
    -u GIT_ALTERNATE_OBJECT_DIRECTORIES -u GIT_COMMON_DIR \
    mix test
TEST_EXIT=$?
set -e

# Restore the clean index (tests may have modified it via the inherited GIT_INDEX_FILE)
cp "$INDEX_BACKUP" "$INDEX_FILE"
rm -f "$INDEX_BACKUP"

if [ $TEST_EXIT -eq 1 ]; then
    echo "ERROR: Tests are failing. Fix them before committing."
    exit 1
fi

# Beads JSONL flush — only in the main worktree, not in git worktrees.
# bd sync runs git commands relative to the current directory; running it in a
# linked worktree creates stray commits on the feature branch.
if command -v bd >/dev/null 2>&1; then
    if git rev-parse --git-dir >/dev/null 2>&1; then
        # Skip beads sync entirely when running inside a linked worktree
        if [ "$(git rev-parse --git-dir)" = "$(git rev-parse --git-common-dir)" ]; then
            BEADS_DIR=""
            if [ -d .beads ]; then
                BEADS_DIR=".beads"
            fi

            if [ -n "$BEADS_DIR" ]; then
                if [ -f "$BEADS_DIR/metadata.json" ]; then
                    if grep -q '"backend"[[:space:]]*:[[:space:]]*"dolt"' "$BEADS_DIR/metadata.json" 2>/dev/null; then
                        exit 0
                    fi
                fi

                bd sync --flush-only >/dev/null 2>&1 || true

                if [ -f "$BEADS_DIR/issues.jsonl" ]; then
                    git add "$BEADS_DIR/issues.jsonl" 2>/dev/null || true
                fi
            fi
        fi
    fi
fi

exit 0
