{
  "openapi": "3.0.3",
  "info": {
    "title": "LowEndInsight API",
    "description": "OSS risk (bus-factor) analysis service. Analyzes git repositories for contributor risk, commit currency, and other supply-chain risk indicators.",
    "version": "0.9.2",
    "license": {
      "name": "BSD 3-Clause",
      "url": "https://opensource.org/licenses/BSD-3-Clause"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Current host"
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/v1/analyze": {
      "post": {
        "summary": "Submit URLs for analysis",
        "description": "Accepts a list of git repository URLs and returns an analysis report. Supports three cache modes: `blocking` (waits for completion), `async` (returns immediately with a job UUID to poll), and `stale` (returns stale cached data if available while refreshing in the background).",
        "operationId": "analyzeUrls",
        "tags": ["Analysis"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalyzeRequest"
              },
              "examples": {
                "basic": {
                  "summary": "Analyze two repos (async)",
                  "value": {
                    "urls": [
                      "https://github.com/kitplummer/clikan",
                      "https://github.com/kitplummer/xmpp4rails"
                    ]
                  }
                },
                "blocking": {
                  "summary": "Blocking mode with timeout",
                  "value": {
                    "urls": [
                      "https://github.com/kitplummer/clikan"
                    ],
                    "cache_mode": "blocking",
                    "cache_timeout": 60000
                  }
                },
                "stale": {
                  "summary": "Accept stale cached data",
                  "value": {
                    "urls": [
                      "https://github.com/kitplummer/clikan"
                    ],
                    "cache_mode": "stale"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Analysis complete (blocking/stale with all cached) or async job created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalysisReport"
                },
                "example": {
                  "state": "complete",
                  "uuid": "ae88a430-3e1f-11ea-a207-0242ac110007",
                  "report": {
                    "uuid": "aec93c7a-3e1f-11ea-8579-0242ac110007",
                    "repos": [
                      {
                        "data": {
                          "repo": "https://github.com/kitplummer/clikan",
                          "risk": "critical",
                          "results": {
                            "commit_currency_risk": "medium",
                            "commit_currency_weeks": 51,
                            "contributor_count": 2,
                            "contributor_risk": "high",
                            "functional_contributors": 1,
                            "functional_contributors_risk": "critical",
                            "large_recent_commit_risk": "medium",
                            "recent_commit_size_in_percent_of_codebase": 0.08
                          },
                          "config": {}
                        },
                        "header": {
                          "uuid": "aec932de-3e1f-11ea-9ac3-0242ac110007",
                          "start_time": "2020-01-23T20:33:58.137963Z",
                          "end_time": "2020-01-23T20:33:58.554693Z",
                          "duration": 0,
                          "library_version": "0.3.1",
                          "source_client": "lei-get"
                        }
                      }
                    ]
                  },
                  "metadata": {
                    "repo_count": 1,
                    "times": {
                      "start_time": "2020-01-23T20:33:58.131642Z",
                      "end_time": "2020-01-23T20:33:58.555362Z",
                      "duration": 0
                    },
                    "risk_counts": {
                      "critical": 1
                    },
                    "cache_status": {
                      "hits": 0,
                      "misses": 1,
                      "per_repo": ["miss"]
                    }
                  }
                }
              }
            }
          },
          "202": {
            "description": "Analysis did not complete within timeout (blocking mode only)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IncompleteResponse"
                },
                "example": {
                  "state": "incomplete",
                  "uuid": "ae88a430-3e1f-11ea-a207-0242ac110007",
                  "error": "analysis did not complete within 30000ms timeout"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "description": "Invalid request body or invalid URLs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": "this is a POSTful service, JSON body with valid git url param required and content-type set to application/json.  e.g. {\"urls\": [\"https://gitrepo/org/repo\"]}"
                }
              }
            }
          }
        }
      }
    },
    "/v1/analyze/{uuid}": {
      "get": {
        "summary": "Fetch analysis result by UUID",
        "description": "Retrieves a previously submitted analysis job. If the job is incomplete, the server attempts to refresh it from cache before returning.",
        "operationId": "getAnalysis",
        "tags": ["Analysis"],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "description": "UUID returned from POST /v1/analyze",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Analysis report (complete or refreshed)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalysisReport"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "description": "No job found for the given UUID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": "invalid UUID provided, no job found."
                }
              }
            }
          }
        }
      }
    },
    "/v1/job/{id}": {
      "get": {
        "summary": "Fetch job by ID",
        "description": "Alias for GET /v1/analyze/:uuid. Retrieves a job by its ID.",
        "operationId": "getJob",
        "tags": ["Analysis"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Job UUID",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job report",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalysisReport"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "description": "Job not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": "invalid UUID provided, no job found."
                }
              }
            }
          }
        }
      }
    },
    "/v1/analyze/sbom": {
      "post": {
        "summary": "Analyze an SBOM",
        "description": "Accepts a CycloneDX or SPDX JSON SBOM, extracts git repository URLs from it, and runs LowEndInsight analysis on each. Default cache mode is `async`.",
        "operationId": "analyzeSbom",
        "tags": ["Analysis"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SbomRequest"
              },
              "examples": {
                "cyclonedx": {
                  "summary": "CycloneDX SBOM",
                  "value": {
                    "sbom": {
                      "bomFormat": "CycloneDX",
                      "specVersion": "1.4",
                      "components": [
                        {
                          "type": "library",
                          "name": "clikan",
                          "externalReferences": [
                            {
                              "type": "vcs",
                              "url": "https://github.com/kitplummer/clikan"
                            }
                          ]
                        }
                      ]
                    }
                  }
                },
                "blocking": {
                  "summary": "SBOM with blocking mode",
                  "value": {
                    "sbom": {},
                    "cache_mode": "blocking",
                    "cache_timeout": 120000
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SBOM analysis complete",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/AnalysisReport"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "sbom_analysis": {
                          "type": "boolean",
                          "example": true
                        },
                        "sbom_urls_found": {
                          "type": "integer",
                          "example": 5
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "202": {
            "description": "SBOM analysis timed out (blocking mode)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "state": {
                      "type": "string",
                      "example": "incomplete"
                    },
                    "uuid": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "sbom_urls_found": {
                      "type": "integer"
                    },
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "description": "Invalid SBOM or parse error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "examples": {
                  "missing_sbom": {
                    "value": {
                      "error": "POST body must contain 'sbom' field with CycloneDX or SPDX JSON"
                    }
                  },
                  "no_urls": {
                    "value": {
                      "error": "no git URLs found in SBOM"
                    }
                  },
                  "parse_error": {
                    "value": {
                      "error": "SBOM parse error: invalid format"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/cache/export": {
      "get": {
        "summary": "Export cache",
        "description": "Exports all cached analysis reports as JSON. Intended for creating distributable cache snapshots for air-gapped deployments. Returns the file as a download attachment.",
        "operationId": "exportCache",
        "tags": ["Cache"],
        "responses": {
          "200": {
            "description": "Cache export as JSON download",
            "headers": {
              "Content-Disposition": {
                "schema": {
                  "type": "string",
                  "example": "attachment; filename=\"lei-cache-export.json\""
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CacheExport"
                },
                "example": {
                  "entries": [
                    {
                      "key": "github:kitplummer/clikan:latest",
                      "data": {},
                      "ttl_remaining": 2592000
                    }
                  ],
                  "stats": {
                    "count": 1,
                    "exported_at": "2024-01-01T00:00:00Z",
                    "format_version": "1.0"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/cache/import": {
      "post": {
        "summary": "Import cache",
        "description": "Imports pre-warmed cache entries previously exported via GET /v1/cache/export. Useful for bootstrapping air-gapped deployments with known-good analysis data.",
        "operationId": "importCache",
        "tags": ["Cache"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CacheImportRequest"
              },
              "example": {
                "entries": [
                  {
                    "key": "github:kitplummer/clikan:latest",
                    "data": {}
                  }
                ],
                "overwrite": false,
                "ttl": 2592000
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CacheImportResponse"
                },
                "example": {
                  "success": true,
                  "stats": {
                    "imported": 5,
                    "skipped": 2,
                    "errors": 0,
                    "total": 7,
                    "imported_at": "2024-01-01T00:00:00Z",
                    "ttl_applied": 2592000
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "422": {
            "description": "Missing entries array",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "error": "POST body must contain 'entries' array from cache export"
                }
              }
            }
          }
        }
      }
    },
    "/v1/cache/stats": {
      "get": {
        "summary": "Get cache statistics",
        "description": "Returns current cache statistics including total entry count and breakdown by ecosystem (e.g., github, gitlab, bitbucket).",
        "operationId": "cacheStats",
        "tags": ["Cache"],
        "responses": {
          "200": {
            "description": "Cache statistics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CacheStats"
                },
                "example": {
                  "total_entries": 42,
                  "by_ecosystem": {
                    "github": 35,
                    "gitlab": 5,
                    "bitbucket": 2
                  },
                  "checked_at": "2024-01-01T00:00:00Z"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/gh_trending": {
      "get": {
        "summary": "List configured trending languages",
        "description": "Returns an HTML page listing all configured programming languages that can be analyzed for GitHub trending repositories. Each language links to its trending analysis report.",
        "operationId": "listGhTrendingLanguages",
        "tags": ["GitHub Trending"],
        "security": [],
        "responses": {
          "200": {
            "description": "HTML page listing available languages",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/gh_trending/{language}": {
      "get": {
        "summary": "Get trending report for a language",
        "description": "Returns an HTML page displaying the LowEndInsight analysis report for trending GitHub repositories in the specified language. Results come from the most recent analysis run triggered via POST /v1/gh_trending/process. If no analysis has been run yet, an empty report is shown.",
        "operationId": "getGhTrendingByLanguage",
        "tags": ["GitHub Trending"],
        "security": [],
        "parameters": [
          {
            "name": "language",
            "in": "path",
            "required": true,
            "description": "Programming language to get trending analysis for (e.g. elixir, python, rust)",
            "schema": {
              "type": "string"
            },
            "examples": {
              "elixir": {
                "value": "elixir"
              },
              "python": {
                "value": "python"
              },
              "rust": {
                "value": "rust"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "HTML page with trending analysis report for the language",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/v1/gh_trending/process": {
      "post": {
        "summary": "Trigger GitHub trending analysis",
        "description": "Kicks off a background task to analyze all configured trending languages from GitHub. For each language, fetches the daily trending repositories, optionally filters by repository size, and runs LowEndInsight analysis on the top N repos (configured via LEI_NUM_OF_REPOS, default 10). Results are cached in Redis and viewable via GET /gh_trending/:language. Returns immediately while processing continues in the background.",
        "operationId": "processGhTrending",
        "tags": ["GitHub Trending"],
        "responses": {
          "200": {
            "description": "Processing started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "example": "Processing languages..."
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token using HS256. All /v1/* endpoints require authentication. Pass as `Authorization: Bearer <token>`."
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid JWT token",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "Please make sure you have authentication header"
                }
              }
            }
          }
        }
      }
    },
    "schemas": {
      "AnalyzeRequest": {
        "type": "object",
        "required": ["urls"],
        "properties": {
          "urls": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "List of git repository URLs to analyze",
            "example": ["https://github.com/kitplummer/clikan"]
          },
          "cache_mode": {
            "type": "string",
            "enum": ["blocking", "async", "stale"],
            "default": "blocking",
            "description": "`blocking` waits for results (up to cache_timeout). `async` returns immediately with a UUID to poll. `stale` returns stale cache if available and refreshes in background."
          },
          "cache_timeout": {
            "type": "integer",
            "default": 30000,
            "description": "Timeout in milliseconds for blocking mode. Analysis that exceeds this returns 202 with a UUID to poll later."
          }
        }
      },
      "SbomRequest": {
        "type": "object",
        "required": ["sbom"],
        "properties": {
          "sbom": {
            "type": "object",
            "description": "CycloneDX or SPDX JSON SBOM object. Git repository URLs are extracted from component external references."
          },
          "cache_mode": {
            "type": "string",
            "enum": ["blocking", "async", "stale"],
            "default": "async",
            "description": "Cache mode (defaults to async for SBOMs due to potentially large number of repos)"
          },
          "cache_timeout": {
            "type": "integer",
            "default": 60000,
            "description": "Timeout in milliseconds for blocking mode"
          }
        }
      },
      "AnalysisReport": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "enum": ["complete", "incomplete"],
            "description": "Whether all repos have been analyzed"
          },
          "uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Job UUID for polling"
          },
          "report": {
            "$ref": "#/components/schemas/Report"
          },
          "metadata": {
            "$ref": "#/components/schemas/Metadata"
          }
        }
      },
      "Report": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "repos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RepoReport"
            }
          }
        }
      },
      "RepoReport": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/RepoData"
          },
          "header": {
            "$ref": "#/components/schemas/RepoHeader"
          }
        }
      },
      "RepoData": {
        "type": "object",
        "properties": {
          "repo": {
            "type": "string",
            "format": "uri",
            "description": "The analyzed repository URL"
          },
          "risk": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Overall risk level for this repo"
          },
          "results": {
            "$ref": "#/components/schemas/RepoResults"
          },
          "config": {
            "$ref": "#/components/schemas/RiskConfig"
          },
          "project_types": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "description": "Detected project types and their indicator files"
          }
        }
      },
      "RepoResults": {
        "type": "object",
        "properties": {
          "commit_currency_risk": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Risk based on how recently the repo was committed to"
          },
          "commit_currency_weeks": {
            "type": "integer",
            "description": "Weeks since last commit"
          },
          "contributor_count": {
            "type": "integer",
            "description": "Total number of unique contributors"
          },
          "contributor_risk": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Risk based on contributor count"
          },
          "functional_contributor_names": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Names of contributors making the bulk of contributions"
          },
          "functional_contributors": {
            "type": "integer",
            "description": "Number of contributors making substantive contributions"
          },
          "functional_contributors_risk": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Risk based on concentration of contributions"
          },
          "large_recent_commit_risk": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "Risk based on size of recent commits relative to codebase"
          },
          "recent_commit_size_in_percent_of_codebase": {
            "type": "number",
            "format": "float",
            "description": "Most recent commit size as a fraction of the total codebase"
          }
        }
      },
      "RiskConfig": {
        "type": "object",
        "description": "Risk threshold configuration used for this analysis",
        "properties": {
          "critical_contributor_level": {
            "type": "integer"
          },
          "high_contributor_level": {
            "type": "integer"
          },
          "medium_contributor_level": {
            "type": "integer"
          },
          "critical_currency_level": {
            "type": "integer"
          },
          "high_currency_level": {
            "type": "integer"
          },
          "medium_currency_level": {
            "type": "integer"
          },
          "critical_large_commit_level": {
            "type": "number"
          },
          "high_large_commit_level": {
            "type": "number"
          },
          "medium_large_commit_level": {
            "type": "number"
          },
          "critical_functional_contributors_level": {
            "type": "integer"
          },
          "high_functional_contributors_level": {
            "type": "integer"
          },
          "medium_functional_contributors_level": {
            "type": "integer"
          }
        }
      },
      "RepoHeader": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string",
            "format": "uuid"
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "duration": {
            "type": "integer",
            "description": "Analysis duration in seconds"
          },
          "library_version": {
            "type": "string",
            "description": "LowEndInsight library version"
          },
          "source_client": {
            "type": "string",
            "description": "Client identifier (e.g. lei-get)"
          }
        }
      },
      "Metadata": {
        "type": "object",
        "properties": {
          "repo_count": {
            "type": "integer"
          },
          "times": {
            "type": "object",
            "properties": {
              "start_time": {
                "type": "string",
                "format": "date-time"
              },
              "end_time": {
                "type": "string",
                "format": "date-time"
              },
              "duration": {
                "type": "integer",
                "description": "Total duration in seconds"
              }
            }
          },
          "risk_counts": {
            "type": "object",
            "description": "Count of repos at each risk level",
            "properties": {
              "critical": {
                "type": "integer"
              },
              "high": {
                "type": "integer"
              },
              "medium": {
                "type": "integer"
              },
              "low": {
                "type": "integer"
              }
            }
          },
          "cache_status": {
            "type": "object",
            "description": "Cache performance for this request",
            "properties": {
              "hits": {
                "type": "integer"
              },
              "misses": {
                "type": "integer"
              },
              "per_repo": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["hit", "miss", "stale"]
                }
              }
            }
          }
        }
      },
      "IncompleteResponse": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "enum": ["incomplete"]
          },
          "uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Poll GET /v1/analyze/{uuid} for the completed result"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "CacheExport": {
        "type": "object",
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CacheEntry"
            }
          },
          "stats": {
            "type": "object",
            "properties": {
              "count": {
                "type": "integer"
              },
              "exported_at": {
                "type": "string",
                "format": "date-time"
              },
              "format_version": {
                "type": "string"
              }
            }
          }
        }
      },
      "CacheEntry": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Cache key in format ecosystem:package:version",
            "example": "github:kitplummer/clikan:latest"
          },
          "data": {
            "type": "object",
            "description": "The cached analysis report"
          },
          "ttl_remaining": {
            "type": "integer",
            "description": "Seconds remaining before this entry expires"
          }
        }
      },
      "CacheImportRequest": {
        "type": "object",
        "required": ["entries"],
        "properties": {
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CacheEntry"
            }
          },
          "overwrite": {
            "type": "boolean",
            "default": false,
            "description": "If true, overwrite existing cache entries"
          },
          "ttl": {
            "type": "integer",
            "description": "TTL in seconds for imported entries. Defaults to the server's configured cache_ttl_seconds."
          }
        }
      },
      "CacheImportResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "stats": {
            "type": "object",
            "properties": {
              "imported": {
                "type": "integer"
              },
              "skipped": {
                "type": "integer"
              },
              "errors": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              },
              "imported_at": {
                "type": "string",
                "format": "date-time"
              },
              "ttl_applied": {
                "type": "integer"
              }
            }
          }
        }
      },
      "CacheStats": {
        "type": "object",
        "properties": {
          "total_entries": {
            "type": "integer"
          },
          "by_ecosystem": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            },
            "example": {
              "github": 35,
              "gitlab": 5
            }
          },
          "checked_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Analysis",
      "description": "Core analysis endpoints for evaluating OSS repository risk"
    },
    {
      "name": "Cache",
      "description": "Cache management for distributable/air-gapped deployments"
    },
    {
      "name": "GitHub Trending",
      "description": "GitHub trending repository analysis"
    }
  ]
}
