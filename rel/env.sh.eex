#!/bin/sh

# Fly.io uses IPv6 for internal networking and DNS.
# The BEAM needs an explicit inet config to resolve via fly's IPv6 DNS.

export RELEASE_DISTRIBUTION=sname
export RELEASE_NODE=lowendinsight_get

# Write Erlang inet config that forces IPv6 DNS resolution
export RELEASE_TMP="${RELEASE_TMP:-/tmp}"
cat > "${RELEASE_TMP}/erl_inetrc" <<INETRC
{lookup, [file, native]}.
{inet6, true}.
INETRC

export ERL_INETRC="${RELEASE_TMP}/erl_inetrc"
export ERL_AFLAGS="-proto_dist inet6_tcp"
